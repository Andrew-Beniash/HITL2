# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: model to use for document chat (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: max tokens the model may return per reply (default: 1024)
OPENAI_MAX_TOKENS=1024

# Optional: system prompt prepended to every conversation
# Leave blank to use the built-in document-assistant prompt
OPENAI_SYSTEM_PROMPT=
